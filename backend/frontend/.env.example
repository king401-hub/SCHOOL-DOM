VITE_API_BASE_URL=
VITE_ENABLE_SERVICE_WORKER=true
VITE_LANDING_PAGE_URL=

# Use an absolute HTTPS backend URL for Capacitor/native builds, for example:
# VITE_API_BASE_URL=https://schooldom.academy
#
# VITE_ENABLE_SERVICE_WORKER gates both PWA install/offline caching AND browser
# push notifications (Web Push needs an active service worker to receive push
# events even when Chrome is closed). Re-enabled after auditing
# service-worker.js: it does network-first fetch for page navigations and only
# cache-first for hash-named build assets, plus versioned cache cleanup on
# activate, so a new deploy is picked up instead of serving a stale cached app.
# Set back to false only if a new staleness issue turns up.

# VITE_LANDING_PAGE_URL: where the "back to home" arrow on the sign-in screen
# should go. Leave blank to default to "/" in production builds (nginx serves
# the landing page at the site root) or http://localhost:5174 in local dev
# (the landing-page project's dev server, npm run dev in backend/landing-page).

# Student CBT desktop client:
# set this before running npm run desktop:student on each student PC.
# Example: SCHOOLDOM_CBT_SERVER_URL=http://192.168.1.20:5173
