VITE_API_BASE_URL=
VITE_ENABLE_SERVICE_WORKER=false

# Use an absolute HTTPS backend URL for Capacitor/native builds, for example:
# VITE_API_BASE_URL=https://schooldom.academy
#
# Leave VITE_ENABLE_SERVICE_WORKER=false while cleaning up stale deployed PWAs.
# Set it to true only after /service-worker.js and /manifest.webmanifest are
# intentionally deployed again and all API calls work without a service worker.

# Student CBT desktop client:
# set this before running npm run desktop:student on each student PC.
# Example: SCHOOLDOM_CBT_SERVER_URL=http://192.168.1.20:5173
