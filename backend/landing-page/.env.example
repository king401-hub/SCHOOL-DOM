# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# VITE_ADMIN_APP_URL: where the sign-up success screen's "Go to Dashboard"
# button goes. Leave blank to default to "/app/" in production (same-origin,
# nginx serves the admin SPA there) or http://localhost:5173/ in local dev
# (the admin SPA's own dev server, npm run dev in backend/frontend).
# Note: in local dev the two apps run on different origins/ports, so the
# session this page writes to localStorage won't be visible to the admin
# app there — you'll land on its sign-in form and need to sign in manually.
# This only auto-logs you in when both apps share an origin, i.e. production.
VITE_ADMIN_APP_URL=
