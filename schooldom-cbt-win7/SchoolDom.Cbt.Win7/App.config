<?xml version="1.0" encoding="utf-8" ?>
<configuration>
  <startup>
    <!-- .NET 4.0 is the last version that runs on Windows 7 RTM without SP1 -->
    <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.0" />
  </startup>

  <appSettings>
    <!-- Default cloud URL. Change this to target a different environment (staging, self-hosted). -->
    <add key="CloudUrl" value="https://schooldom.academy" />
  </appSettings>

  <runtime>
    <!-- Disable server GC; admin machine may be single-core or low-RAM -->
    <gcServer enabled="false"/>
    <gcConcurrent enabled="true"/>

    <assemblyBinding xmlns="urn:schemas-microsoft-com:asm.v1">
      <dependentAssembly>
        <assemblyIdentity name="System.Net.Http" publicKeyToken="b03f5f7f11d50a3a" culture="neutral"/>
        <bindingRedirect oldVersion="0.0.0.0-4.2.0.0" newVersion="4.0.0.0"/>
      </dependentAssembly>
    </assemblyBinding>
  </runtime>

  <system.net>
    <settings>
      <httpWebRequest useUnsafeHeaderParsing="true"/>
      <connectionManagement>
        <add address="*" maxconnection="4"/>
      </connectionManagement>
    </settings>
    <defaultProxy enabled="true" useDefaultCredentials="false">
      <proxy usesystemdefault="true"/>
    </defaultProxy>
  </system.net>
</configuration>
