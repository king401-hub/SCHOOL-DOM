# Paystack configuration
PAYSTACK_TEST_MODE=true
PAYSTACK_SECRET_KEY_TEST=sk_test_your_key_here
PAYSTACK_PUBLIC_KEY_TEST=pk_test_your_key_here
PAYSTACK_SECRET_KEY_LIVE=sk_live_your_key_here
PAYSTACK_PUBLIC_KEY_LIVE=pk_live_your_key_here

# Optional legacy single-pair fallback (only use if you don't set the test/live pairs)
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=

# API host (override only if Paystack changes domains)
PAYSTACK_BASE_URL=https://api.paystack.co
