# Flutterwave configuration
# Use live credentials by default for real payments. Set FLUTTERWAVE_TEST_MODE=true only for sandbox testing.
FLUTTERWAVE_TEST_MODE=false
FLUTTERWAVE_SECRET_KEY_LIVE=FLWSECK_LIVE_your_real_key_here
FLUTTERWAVE_PUBLIC_KEY_LIVE=FLWPUBK_LIVE_your_real_key_here
FLUTTERWAVE_SECRET_KEY_TEST=FLWSECK_TEST_your_key_here
FLUTTERWAVE_PUBLIC_KEY_TEST=FLWPUBK_TEST_your_key_here

# Optional single-pair fallback
FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_PUBLIC_KEY=

FLUTTERWAVE_BASE_URL=https://api.flutterwave.com/v3
FLUTTERWAVE_CALLBACK_URL=

# Optional service IP whitelist. Add your public IP or CIDR ranges before enabling.
# Example: IP_WHITELIST=203.0.113.10,198.51.100.0/24
IP_WHITELIST_ENABLED=false
IP_WHITELIST=
IP_WHITELIST_USE_X_FORWARDED_FOR=true

# Email configuration for admin OTP verification
# Create a fresh Gmail app password and keep it only in your local .env file.
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-new-gmail-app-password
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=SchoolDom <your-email@gmail.com>
OTP_EMAIL_TOKEN_VALIDITY=600
OTP_EMAIL_THROTTLE_FACTOR=1
