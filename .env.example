# Payment provider (kuda | flutterwave | paystack)
PAYMENT_PROVIDER=paystack

# ── Paystack ──────────────────────────────────────────────
PAYSTACK_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxx
PAYSTACK_PUBLIC_KEY=pk_live_xxxxxxxxxxxxxxxxxxxx
PAYSTACK_BASE_URL=https://api.paystack.co
# Your Schooldom subaccount code on Paystack (receives ₦100/fee)
PAYSTACK_SCHOOLDOM_SUBACCOUNT=ACCT_xxxxxxxxxxxxxxxx
# URL Paystack redirects to after payment (your frontend verify page)
PAYSTACK_CALLBACK_URL=https://schooldom.academy/pay/verify

# ── Sendchamp (SMS only) ───────────────────────────────────
SENDCHAMP_API_KEY=sendchamp-live-xxxxxxxxxxxxxxxxxxxxxxxx
# Registered sender ID (max 11 chars, no spaces)
SENDCHAMP_SENDER_ID=SchoolDom
# Route: dnd (reaches DND numbers) | non_dnd | international
SENDCHAMP_ROUTE=dnd

# ── eBulkSMS (Child Monitor SMS alerts) ───────────────────
EBULKSMS_USERNAME=your_email@example.com
EBULKSMS_APIKEY=your_ebulksms_api_key

# ── Termii (WhatsApp) ─────────────────────────────────────
TERMII_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Sender ID registered on your Termii account (3-11 alphanumeric chars)
TERMII_WHATSAPP_FROM=YourSenderID
TERMII_BASE_URL=https://api.ng.termii.com

# ── Schooldom Secretary AI ─────────────────────────────────
# Ollama model to use for the admin secretary (must support tool calling)
# Options: llama3.2:3b | llama3.1:8b | gemma3:4b
SECRETARY_OLLAMA_MODEL=llama3.2:3b

# ── Web Push (browser notifications, even when Chrome is closed) ──────────
# Generate a real pair with:
#   backend: venv/Scripts/python -c "from py_vapid import Vapid02; ..."
# (see the comment above VAPID_PUBLIC_KEY in config/settings.py for the exact
# snippet). Push silently no-ops if either key is left blank.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_CLAIM_EMAIL=mailto:support@schooldom.academy

# Celery / Redis
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
CELERY_TASK_TIME_LIMIT=1800

# Public frontend website used in generated links and attendance QR codes.
# Keep NGROK_PUBLIC_URL empty in production so QR codes do not point to a test tunnel.
FRONTEND_BASE_URL=https://schooldom.academy
NGROK_PUBLIC_URL=
CSRF_TRUSTED_ORIGINS=https://schooldom.academy
CORS_ALLOWED_ORIGINS=https://schooldom.academy

# Optional service IP whitelist. Add your public IP or CIDR ranges before enabling.
# Example: IP_WHITELIST=203.0.113.10,198.51.100.0/24
IP_WHITELIST_ENABLED=false
IP_WHITELIST=
IP_WHITELIST_USE_X_FORWARDED_FOR=true

# Email configuration for admin OTP verification and outbound notifications.
# schooldom.com mailboxes are hosted on Hostinger, NOT Gmail — use Hostinger's
# SMTP server and the real mailbox password (no "app password" concept there).
# Gmail example (kept for reference if a gmail.com sender is ever used instead):
#   EMAIL_HOST=smtp.gmail.com, EMAIL_PORT=587, EMAIL_USE_TLS=True, EMAIL_USE_SSL=False
#   Password must be a Google App Password generated for that exact account (requires 2-Step Verification).
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.hostinger.com
EMAIL_PORT=465
EMAIL_HOST_USER=your-email@schooldom.com
EMAIL_HOST_PASSWORD=your-hostinger-mailbox-password
EMAIL_USE_TLS=False
EMAIL_USE_SSL=True
EMAIL_TIMEOUT=10
DEFAULT_FROM_EMAIL=SchoolDom <your-email@schooldom.com>
ADMIN_OTP_ENABLED=true
# Local development only: if SMTP rejects credentials, keep the OTP flow usable
# by printing the admin code in the backend console/log. Disable in production.
ADMIN_OTP_EMAIL_FAILURE_CONSOLE_FALLBACK=true
# Local development only: expose OTP in the API/UI when email delivery is blocked.
ADMIN_OTP_DEBUG_CODE_ENABLED=false
OTP_EMAIL_TOKEN_VALIDITY=600
OTP_EMAIL_THROTTLE_FACTOR=1
