# Payment provider
PAYMENT_PROVIDER=kuda

# Flutterwave configuration
# Use live credentials by default for real payments. Set FLUTTERWAVE_TEST_MODE=true only for sandbox testing.
FLUTTERWAVE_TEST_MODE=false
FLUTTERWAVE_SECRET_KEY_LIVE=FLWSECK_LIVE_your_real_key_here
FLUTTERWAVE_PUBLIC_KEY_LIVE=FLWPUBK_LIVE_your_real_key_here
FLUTTERWAVE_SECRET_KEY_TEST=FLWSECK_TEST_your_key_here
FLUTTERWAVE_PUBLIC_KEY_TEST=FLWPUBK_TEST_your_key_here

# Optional single-pair fallback
FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_PUBLIC_KEY=

FLUTTERWAVE_BASE_URL=https://api.flutterwave.com/v3
FLUTTERWAVE_CALLBACK_URL=
FLUTTERWAVE_AUTO_SETTLE_SCHOOL_FEES=true

# Kuda configuration
KUDA_BASE_URL=
KUDA_API_KEY=
KUDA_CLIENT_ID=
KUDA_CLIENT_SECRET=
KUDA_WEBHOOK_SECRET=
KUDA_TRANSFER_ENDPOINT=/transfers
KUDA_TRANSACTION_VERIFY_ENDPOINT=/transactions/{reference}
KUDA_VIRTUAL_ACCOUNT_ENDPOINT=/virtual-accounts
KUDA_COLLECTION_ACCOUNT_NUMBER=
KUDA_COLLECTION_ACCOUNT_NAME=SchoolDom
KUDA_COLLECTION_BANK_NAME=Kuda Microfinance Bank
KUDA_REQUEST_TIMEOUT=25

# KudiSMS bulk SMS configuration
KUDISMS_TOKEN=
KUDISMS_SENDER_ID=neo
KUDISMS_GATEWAY=2

# Public frontend website used in generated links and attendance QR codes.
# Keep NGROK_PUBLIC_URL empty in production so QR codes do not point to a test tunnel.
FRONTEND_BASE_URL=https://schooldom.academy
NGROK_PUBLIC_URL=
CSRF_TRUSTED_ORIGINS=https://schooldom.academy
CORS_ALLOWED_ORIGINS=https://schooldom.academy

# Optional service IP whitelist. Add your public IP or CIDR ranges before enabling.
# Example: IP_WHITELIST=203.0.113.10,198.51.100.0/24
IP_WHITELIST_ENABLED=false
IP_WHITELIST=
IP_WHITELIST_USE_X_FORWARDED_FOR=true

# Email configuration for admin OTP verification
# Create a fresh Gmail app password and keep it only in your local .env file.
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-new-gmail-app-password
EMAIL_USE_TLS=True
EMAIL_TIMEOUT=10
DEFAULT_FROM_EMAIL=SchoolDom <your-email@gmail.com>
ADMIN_OTP_ENABLED=true
# Local development only: if SMTP rejects credentials, keep the OTP flow usable
# by printing the admin code in the backend console/log. Disable in production.
ADMIN_OTP_EMAIL_FAILURE_CONSOLE_FALLBACK=true
# Local development only: expose OTP in the API/UI when email delivery is blocked.
ADMIN_OTP_DEBUG_CODE_ENABLED=false
OTP_EMAIL_TOKEN_VALIDITY=600
OTP_EMAIL_THROTTLE_FACTOR=1
