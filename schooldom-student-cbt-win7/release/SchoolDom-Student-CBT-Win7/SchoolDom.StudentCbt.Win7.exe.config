<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <startup>
    <!-- .NET 4.0 is the last version that runs on Windows 7 RTM (no SP1 needed) -->
    <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.0"/>
  </startup>

  <runtime>
    <!-- Disable server GC on single-core / low-RAM machines common in cybercafes -->
    <gcServer enabled="false"/>
    <gcConcurrent enabled="true"/>

    <!-- Binding redirect so System.Net.Http 2.x on .NET 4.0 resolves correctly -->
    <assemblyBinding xmlns="urn:schemas-microsoft-com:asm.v1">
      <dependentAssembly>
        <assemblyIdentity name="System.Net.Http" publicKeyToken="b03f5f7f11d50a3a" culture="neutral"/>
        <bindingRedirect oldVersion="0.0.0.0-4.2.0.0" newVersion="4.0.0.0"/>
      </dependentAssembly>
    </assemblyBinding>
  </runtime>

  <system.net>
    <settings>
      <!-- Fixes some HTTP header parsing quirks on Win7 RTM -->
      <httpWebRequest useUnsafeHeaderParsing="true"/>
      <!-- LAN-only: allow more parallel connections to the admin server -->
      <connectionManagement>
        <add address="*" maxconnection="4"/>
      </connectionManagement>
    </settings>
    <!-- Disable proxy auto-detect; the student app is LAN-only -->
    <defaultProxy enabled="false" useDefaultCredentials="false">
      <proxy usesystemdefault="false"/>
    </defaultProxy>
  </system.net>
</configuration>
